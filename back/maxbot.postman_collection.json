        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "\r",
                  "pm.test(\"login status is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "if (res.token) {\r",
                  "    pm.environment.set(\"admin_token\", res.token);\r",
                  "} else if (res.access_token) {\r",
                  "    pm.environment.set(\"admin_token\", res.access_token);\r",
                  "} else {\r",
                  "    console.log(\"Token not found in response:\", res);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
